# ChipIn — Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # Service key (never exposed client-side)

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# NextAuth / Google OAuth
NEXTAUTH_SECRET=a-random-strong-secret-32-chars
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin — your Google email (auto-promoted to admin on first login)
ADMIN_EMAIL=you@email.com

# Stripe — fundraiser creation fee in cents (499 = €4.99)
CREATION_FEE_AMOUNT=499
