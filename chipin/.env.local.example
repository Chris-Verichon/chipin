# ============================================================
# ChipIn — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # Clé service (jamais exposée côté client)

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# NextAuth / Google OAuth
NEXTAUTH_SECRET=un-secret-aleatoire-fort-32-chars
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin — ton Google email (sera promu admin automatiquement au 1er login)
ADMIN_EMAIL=ton@email.com

# Stripe — Prix de création de cagnotte (en centimes, 499 = 4.99€)
CREATION_FEE_AMOUNT=499
